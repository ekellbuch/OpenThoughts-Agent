export DAYTONA_API_KEY='YOUR_DAYTONA_API_KEY'
# NOTE: do NOT set DAYTONA_TARGET here. Harbor's daytona env appends the
# target to the auto-snapshot name (harbor__<hash>__<target>__snapshot)
# which then fails to match our pre-built `harbor__<hash>__snapshot`,
# and Harbor falls through to a declarative Dockerfile build (rejected
# by the RL org with `DaytonaValidationError: declarative builds are
# not allowed`, slower than snapshot attach elsewhere). The codebase
# no longer needs DAYTONA_TARGET — leave it unset.
export HF_TOKEN='YOUR_HF_TOKEN'
export SUPABASE_URL='YOUR_SUPABASE_URL'
export SUPABASE_ANON_KEY='YOUR_SUPABASE_ANON_KEY'
export SUPABASE_SERVICE_ROLE_KEY='YOUR_SUPABASE_SERVICE_ROLE_KEY'
export SSH_KEY="$HOME/.ssh/id_ed25519_jsc"
