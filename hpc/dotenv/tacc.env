export WANDB_ENTITY=dogml
export WANDB_PROJECT=OpenThoughts-Agent
export DCFT=$SCRATCH/OpenThoughts-Agent
export DCFT_GROUP=G-827553
export CHECKPOINTS_DIR=$SCRATCH/checkpoints
export MODELS_DIR=$HF_HUB_CACHE
export DATASETS_DIR=$HF_HUB_CACHE
export TOKENIZED_DATASETS_DIR=$SCRATCH/tokenized_datasets
export DCFT_CONDA=$SCRATCH/miniconda3
dcft_activate() {
  # shellcheck disable=SC1090
  source "$DCFT_CONDA/bin/activate" otagent
  export PYTHONPATH="${DCFT_PRIVATE:-$DCFT}${PYTHONPATH:+:$PYTHONPATH}"
}
export DCFT_ACTIVATE_ENV=dcft_activate
export VLLM_CACHE_ROOT=$SCRATCH/vllm
export HF_CACHE_DIR=$SCRATCH/hf_cache
export HF_HUB_CACHE=$SCRATCH/hub   # shared, READ-ONLY raw hub cache (model + dataset parquet)
# SFT: force every per-rank WRITE cache (HF-datasets arrow build+lock, Triton/Inductor,
# Ray, TMPDIR, XDG) onto NODE-LOCAL /tmp instead of the shared experiment work area.
# Vista gh /tmp is 261G XFS, and shared Lustre flock BREAKS under 16-way concurrency
# (ENOLCK/ESTALE — killed SFT 815251/815508/815530 on BOTH the axolotl FileLockLoader lock
# and the HF datasets builder lock). Read by the universal_sft.sbatch write-cache guard,
# which then routes HF_DATASETS_CACHE/TRITON_CACHE_DIR/etc. node-local (per-node, uncontended).
# HF_HUB_CACHE stays shared+populated -> node-local arrow builds read cached parquet, no re-download.
# (Scoped to SFT: only the SFT sbatch reads this var; eval/datagen/RL ignore it.)
export SFT_KEEP_TMPDIR_LOCAL=1
export DC_AGENT_SECRET_ENV=$SCRATCH/keys.env
# SkyRL home directory (clone from https://github.com/penfever/SkyRL.git)
source "${DCFT_PRIVATE:-$DCFT}/hpc/shell_utils/resolve_rl_repo.sh"
export SKYRL_HOME="$(resolve_rl_repo_dir "$SCRATCH")"
export GCS_CREDENTIALS_PATH=$SCRATCH/.gcs_credentials.json
export PYTORCH_CUDA_ALLOW_TF32=1          # turns on TF32 for GEMM (same as torch.set_float32_matmul_precision("high"))
export PYTORCH_CUDNN_ALLOW_TF32=1         # optional, lets cuDNN kernels use TF32 too
# Keep the repo importable even if Python strips the working directory from sys.path.
# Include SKYRL_HOME/skyrl-train for examples/terminal_bench entrypoints
export PYTHONPATH="${SKYRL_HOME}/skyrl-train:${DCFT_PRIVATE:-$DCFT}${PYTHONPATH:+:$PYTHONPATH}"
# Your personal email address for notifications
export EMAIL_ADDRESS="bf996@nyu.edu"