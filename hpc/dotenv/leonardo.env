# Leonardo (CINECA) — A100-64GB, 4 GPUs/node, SLURM scheduler
# No internet on compute nodes — use proxychains/SSH tunnel
export WORK=/leonardo_work/EUHPC_E03_068/bfeuer00
export SCRATCH_FAST=/leonardo_scratch/fast/EUHPC_E03_068/bfeuer00
export DCFT=${WORK}/code/OpenThoughts-Agent
export CHECKPOINTS_DIR=${WORK}/experiments
export MODELS_DIR=${WORK}/data/hub
export DATASETS_DIR=${WORK}/data/hub
export HF_HUB_CACHE=${WORK}/data/hub
export HF_CACHE_DIR=${WORK}/data/hub
export HF_HOME=${HF_HUB_CACHE}
export VLLM_CACHE_ROOT=${SCRATCH_FAST}/vllm_cache
export TRITON_CACHE_DIR=${SCRATCH_FAST}/vllm_cache/triton
export FLASHINFER_WORKSPACE_BASE=${SCRATCH_FAST}/vllm_cache/flashinfer

export WANDB_ENTITY=dogml
export WANDB_PROJECT=OpenThoughts-Agent
export WANDB_MODE=offline

export DC_AGENT_SECRET_ENV=${HOME}/secrets.env
export SSH_KEY=$HOME/.ssh/authorized_keys/cineca_keyfile

# Conda activation for batch jobs
export DCFT_ACTIVATE_ENV="source /leonardo_work/EUHPC_E03_068/bfeuer00/miniforge3/etc/profile.d/conda.sh && conda activate otagent && module load cuda/12.6 && source ~/secrets.env && export PYTHONPATH=${DCFT}${PYTHONPATH:+:$PYTHONPATH}"
export DATAGEN_ACTIVATE_ENV="${DCFT_ACTIVATE_ENV}"
export EVALCHEMY_ACTIVATE_ENV="${DCFT_ACTIVATE_ENV}"
export VLLM_ACTIVATE_ENV="${DCFT_ACTIVATE_ENV}"

export PYTORCH_CUDA_ALLOW_TF32=1
export PYTORCH_CUDNN_ALLOW_TF32=1
export PYTHONFAULTHANDLER=1
