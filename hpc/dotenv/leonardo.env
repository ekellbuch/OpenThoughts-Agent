# Leonardo (CINECA) — A100-64GB, 4 GPUs/node, SLURM scheduler
# No internet on compute nodes — use proxychains/SSH tunnel
export WORK=/leonardo_work/AIFAC_5C0_290/bfeuer00
export SCRATCH_FAST=/leonardo_scratch/fast/AIFAC_5C0_290/bfeuer00
export DCFT=${WORK}/code/OpenThoughts-Agent
export CHECKPOINTS_DIR=${WORK}/experiments
export MODELS_DIR=${WORK}/data/hub
export DATASETS_DIR=${WORK}/data/hub
export HF_HUB_CACHE=${WORK}/data/hub
export HF_CACHE_DIR=${WORK}/data/hub
export HF_HOME=${HF_HUB_CACHE}
export TOKENIZED_DATASETS_DIR=${WORK}/data/tokenized_datasets
# --- Scratch + cache redirects: keep everything OFF the tiny node-local /tmp (a ~9.6 GB LV
# that overflows with [Errno 28] No space left during HF datasets arrow spill, triton/inductor
# compile cache, and Ray session dirs — killed Delphi SFT 46313225 on 2026-06-13). Also OFF
# /leonardo_scratch/fast, which was observed 100% full / 0 avail on 2026-06-13. Everything lives
# on $WORK (/leonardo_work, ~95T free). hpc.launch sources this file INSIDE the compute-node
# sbatch, so these take effect for the training/inference process (SLURM_JOB_ID is set there;
# falls back to $$ on the login node). Per-job dirs use ${SLURM_JOB_ID:-$$}; shared caches are
# reused across jobs.
export OT_CACHE_ROOT=${WORK}/cache
export OT_JOB_TMP=${WORK}/jobtmp/${SLURM_JOB_ID:-$$}
mkdir -p "$OT_JOB_TMP/ray" "$OT_CACHE_ROOT"/triton "$OT_CACHE_ROOT"/inductor "$OT_CACHE_ROOT"/xdg "$OT_CACHE_ROOT"/vllm "$OT_CACHE_ROOT"/flashinfer 2>/dev/null || true
# per-job transient scratch (the /tmp replacements)
export TMPDIR=$OT_JOB_TMP
export TMP=$OT_JOB_TMP
export TEMP=$OT_JOB_TMP
export RAY_TMPDIR=$OT_JOB_TMP/ray
# shared persistent compile/runtime caches (moved off the full SCRATCH_FAST → $WORK)
export TRITON_CACHE_DIR=$OT_CACHE_ROOT/triton
export TORCHINDUCTOR_CACHE_DIR=$OT_CACHE_ROOT/inductor
export XDG_CACHE_HOME=$OT_CACHE_ROOT/xdg
export VLLM_CACHE_ROOT=$OT_CACHE_ROOT/vllm
export FLASHINFER_WORKSPACE_BASE=$OT_CACHE_ROOT/flashinfer

export WANDB_ENTITY=dogml
export WANDB_PROJECT=OpenThoughts-Agent
export WANDB_MODE=offline

export DC_AGENT_SECRET_ENV=${HOME}/secrets.env
export SSH_KEY=$HOME/.ssh/leonardo_daytona

# Conda activation for batch jobs
export DCFT_ACTIVATE_ENV="source /leonardo_work/AIFAC_5C0_290/bfeuer00/miniforge3/etc/profile.d/conda.sh && conda activate otagent && source ~/secrets.env && export PYTHONPATH=${DCFT}${PYTHONPATH:+:$PYTHONPATH}"
export DATAGEN_ACTIVATE_ENV="${DCFT_ACTIVATE_ENV}"
export EVALCHEMY_ACTIVATE_ENV="${DCFT_ACTIVATE_ENV}"
export VLLM_ACTIVATE_ENV="${DCFT_ACTIVATE_ENV}"

export PYTORCH_CUDA_ALLOW_TF32=1
export PYTORCH_CUDNN_ALLOW_TF32=1
export PYTHONFAULTHANDLER=1
