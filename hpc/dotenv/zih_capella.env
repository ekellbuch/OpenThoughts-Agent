# ZIH Capella (TU-Dresden) — H100-94GB, 4 GPUs/node, SLURM scheduler, partition `capella`.
# Compute nodes have FULL direct internet egress (HF + Daytona reachable) — no proxy / no offline.
# HARD RULE: /home is 50 GB per user; ALL space-eaters (conda pkgs/envs, HF cache, pip cache, XDG
# caches, TMPDIR) MUST live in the workspace ($SCRATCH), never /home. Workspaces on the `cat`
# Lustre FS are 30-day ttl (2 extensions). NEW workspace path (ws tool naming changed 2026-07):
# /data/cat/ws/befe330h-otagent (was the double-name befe330h-befe330h-otagent).
export SCRATCH=/data/cat/ws/befe330h-otagent
export DCFT=$SCRATCH/OpenThoughts-Agent
export DC_AGENT=$SCRATCH/OpenThoughts-Agent
export DC_AGENT_SECRET_ENV=~/secrets.env
export DCFT_GROUP=p_agents_finetuning
export DCFT_CONDA=$SCRATCH/miniconda3
export DCFT_ENV=otagent
export DCFT_ACTIVATE_ENV="source $DCFT_CONDA/bin/activate $DCFT_ENV && export PYTHONPATH=${DCFT_PRIVATE:-$DCFT}${PYTHONPATH:+:$PYTHONPATH}"
export HF_HUB_CACHE=$SCRATCH/huggingface/hub
export HF_CACHE_DIR=$SCRATCH/huggingface/cache
export HF_HOME=${HF_HUB_CACHE}
# Keep pip + XDG caches OFF the 50 GB /home (conda pkgs/envs already redirected via $DCFT_CONDA/.condarc)
export PIP_CACHE_DIR=$SCRATCH/.cache/pip
export XDG_CACHE_HOME=$SCRATCH/.cache/xdg
export CHECKPOINTS_DIR=$SCRATCH/checkpoints
export MODELS_DIR=$HF_HUB_CACHE
export DATASETS_DIR=$HF_HUB_CACHE
export TOKENIZED_DATASETS_DIR=$SCRATCH/tokenized_datasets
export WANDB_ENTITY=dogml
export WANDB_PROJECT=OpenThoughts-Agent
export VLLM_CACHE_ROOT=$SCRATCH/vllm
# TRITON_CACHE_DIR is set by hpc/shell_utils/triton_cache.sh to use node-local /tmp
# SkyRL home directory (clone from https://github.com/penfever/SkyRL.git)
source "${DCFT_PRIVATE:-$DCFT}/hpc/shell_utils/resolve_rl_repo.sh"
export SKYRL_HOME="$(resolve_rl_repo_dir "$SCRATCH")"
# Keep the repo importable even if Python strips the working directory from sys.path.
# Include SKYRL_HOME/skyrl-train for examples/terminal_bench entrypoints
export PYTHONPATH="${SKYRL_HOME}/skyrl-train:${DCFT_PRIVATE:-$DCFT}${PYTHONPATH:+:$PYTHONPATH}"
# Your personal email address for notifications
export EMAIL_ADDRESS="bf996@nyu.edu"