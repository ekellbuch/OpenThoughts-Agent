# syntax=docker/dockerfile:1
#
# OpenThoughts-Agent — TPU image for datagen + eval.
#
# Stack: vLLM-TPU 0.20.0 (PyTorch/XLA + JAX backend), Harbor + Daytona sandbox
# backend. Bakes the validated [datagen-tpu] resolve documented in
# pyproject.toml (Stage A–D bringup, 2026-05-21).
#
# Single variant only — TPU slice size is a *submit-time* argument on Iris
# (--tpu v6e-4 / v5p-32 / etc.), not a build-time choice, so we don't fan out
# to {1x,4x,8x} the way the GPU images do.
#
# Build (only linux/amd64 — TPU host VMs are x86_64):
#
#   docker buildx build --platform linux/amd64 \
#     -f docker/Dockerfile.tpu \
#     -t ghcr.io/open-thoughts/openthoughts-agent:tpu \
#     --push .
#
# Or via the convenience script:
#
#   ./docker/build_and_push.sh tpu
#
FROM python:3.12-slim

ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    ca-certificates \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# uv handles both venv creation and dependency install (matches gpu-base pattern)
RUN pip3 install --no-cache-dir --upgrade pip uv && \
    uv venv --python 3.12 /opt/openthoughts/.venv

ENV VIRTUAL_ENV=/opt/openthoughts/.venv
ENV PATH="$VIRTUAL_ENV/bin:$PATH"

WORKDIR /opt/openthoughts

# Mirror the COPY set used by the gpu-base image so setuptools.find_packages
# resolves the same way. Source is COPIED here only to register the editable
# install — at runtime the cluster syncs the working tree on top of this layer,
# which is why we keep the install as `-e`.
COPY pyproject.toml ./
COPY README.md ./
COPY eval ./eval
COPY hpc ./hpc
COPY scripts ./scripts
COPY data ./data
COPY database ./database
COPY sft ./sft
COPY rl ./rl
COPY assets ./assets
COPY build_support.py ./
COPY setup.py ./
COPY CLAUDE.md ./
COPY CONTRIBUTING.md ./
COPY LICENSE.txt ./
COPY docker ./docker

ENV UV_HTTP_TIMEOUT=300
ENV UV_RETRIES=5

# datagen-tpu = vllm-tpu 0.20.0 + tpu-inference 0.20.0 + jax/libtpu (transitive)
#               + transformers 5.5.3 (Qwen3.5 hybrid GDN support).
# cloud       = skypilot + GCS/S3 helpers for artifact movement.
# We skip harbor-all on purpose: the Daytona sandbox backend is in base deps
# (harbor[daytona]); the docker / modal extras add nothing on a TPU worker.
# The [tool.uv.sources] map in pyproject.toml routes torch + torchvision to
# the pytorch-cpu index when this extra is active, so the global cu128
# extra-index-url doesn't poison the resolve.
RUN . /opt/openthoughts/.venv/bin/activate && \
    uv pip install -e ".[datagen-tpu,cloud]"

# Pin harbor to an IMMUTABLE COMMIT and force-reinstall from source (mirrors the
# gpu-rl image). The base extra above installs harbor from the FLOATING
# marin-community/harbor@main branch, whose install layer kaniko
# caches by the (unchanged) COPYed pyproject.toml + RUN string — so a harbor bump
# on the branch does NOT bust that cache and a STALE wheel gets baked. Bumping
# HARBOR_COMMIT below changes THIS layer's cache key (guaranteed rebuild), and
# --force-reinstall makes uv rebuild harbor from the exact pinned commit
# regardless of any cached wheel. This is why datagen resume/export-push fixes
# reach the worker deterministically. Bump HARBOR_COMMIT for every harbor change
# that must ship in the image. 22d75039 = harbor main HEAD (2026-07-15) — PR #6
# squash-merged the consolidated penfever/working state into main (was 2dde0bbf on
# the retiring penfever/working branch); harbor now lands via fresh-branch->main.
ENV HARBOR_COMMIT=22d75039694db5c223797d5eec75b5c1ae975ac6
RUN . /opt/openthoughts/.venv/bin/activate && \
    uv pip install --no-deps --force-reinstall \
        "harbor[daytona] @ git+https://github.com/marin-community/harbor.git@${HARBOR_COMMIT}" && \
    python -c "import harbor, importlib.metadata as m; print('baked harbor', m.version('harbor'))" && \
    echo "baked harbor commit: ${HARBOR_COMMIT}"

RUN echo "ulimit -n 65535" >> /etc/profile.d/openthoughts-ulimit.sh

# Force JAX onto TPU rather than letting it auto-detect (which has been known
# to fall back to CPU in some container init paths if libtpu probes early).
ENV JAX_PLATFORMS=tpu

CMD ["bash"]
